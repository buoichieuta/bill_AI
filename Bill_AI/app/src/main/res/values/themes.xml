<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Bill_AI" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
    </style>

    <!-- Premium Dark Theme -->
    <style name="Theme.Bill_AI" parent="Base.Theme.Bill_AI">
        <!-- Night mode specific overrides -->
        <item name="android:windowBackground" tools:targetApi="l">@color/dark_background</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <style name="GlowingButton">
        <item name="android:background">@drawable/bg_glowing_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:elevation">8dp</item>
    </style>

    <style name="PremiumCard">
        <item name="cardBackgroundColor">@color/dark_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>

</resources>