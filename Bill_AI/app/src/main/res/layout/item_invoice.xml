<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp">

    <FrameLayout
        android:id="@+id/flIconContainer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_tag_eating"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvIconEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="☕"
            android:textSize="20sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvVendorName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Quán Cà Phê A"
        android:textColor="#1A2340"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/flIconContainer"
        app:layout_constraintTop_toTopOf="@id/flIconContainer"
        app:layout_constraintEnd_toStartOf="@id/tvAmount"/>

    <TextView
        android:id="@+id/tvTimestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15/10/2023"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="@id/tvVendorName"
        app:layout_constraintTop_toBottomOf="@id/tvVendorName"/>

    <TextView
        android:id="@+id/tvCategoryTag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🍔 Eating"
        android:textColor="#D84315"
        android:textSize="11sp"
        android:background="@drawable/bg_tag_eating"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toStartOf="@id/tvVendorName"
        app:layout_constraintTop_toBottomOf="@id/tvTimestamp"/>

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="120.000 VNĐ"
        android:textColor="#1A2340"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toStartOf="@id/ivMore"
        app:layout_constraintTop_toTopOf="@id/flIconContainer"/>

    <ImageView
        android:id="@+id/ivMore"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_more"
        android:rotation="90"
        app:tint="#BDBDBD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/flIconContainer"
        app:layout_constraintBottom_toBottomOf="@id/flIconContainer"/>

    <View
        android:id="@+id/vDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCategoryTag"/>

</androidx.constraintlayout.widget.ConstraintLayout>