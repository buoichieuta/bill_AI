<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_header_gradient"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:id="@+id/ivAvatarHome"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/circle_avatar"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_report_image"
                    android:padding="2dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/ivAvatarHome"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chiều nay tiêu gì rồi? 👋"
                        android:textColor="@color/app_text_main"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                </LinearLayout>

            </RelativeLayout>

            <!-- AI Suggestion Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvAiSuggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/app_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_search_rounded"
                        android:backgroundTint="@color/primary_blue"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="● AI gợi ý"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvAiHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Bạn đã chi 245.000đ cho ăn uống hôm nay — cao hơn 18% so với hôm qua."
                        android:textColor="@color/app_text_sub"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>




            <!-- Scan Button Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="32dp">

                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_scan_glow_premium"/>
                    
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="10dp"
                        app:cardBackgroundColor="@color/app_bg"
                        app:strokeColor="@color/primary_blue"
                        app:strokeWidth="1dp">
                        <ImageButton
                            android:id="@+id/btnCapture"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/primary_blue"
                            android:background="@null"/>
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Quét hóa đơn"
                    android:textColor="@color/primary_blue"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Summary Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_summary_card_dark"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvSummarySpent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.2M đ"
                        android:textColor="@color/app_text_main"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                    <TextView
                        android:id="@+id/tvSummarySpentDelta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+12% so với tháng trước"
                        android:textColor="@color/spent_red"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_summary_card_dark"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số hóa đơn"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvSummaryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="38"
                        android:textColor="@color/app_text_main"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                    <TextView
                        android:id="@+id/tvSummaryCountDelta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+6 tuần này"
                        android:textColor="#4CAF50"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>


            <!-- Recent Bills Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hóa đơn gần đây"
                    android:textColor="@color/app_text_main"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Xem tất cả"
                    android:textColor="@color/primary_blue"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <!-- Recent Bills header -->
            <!-- Simplified: we'll use a new RecyclerView for Home or just keep it empty for now -> Just a placeholder or a limited rvHomeInvoices -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentInvoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="16dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyRecent"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="center"
                android:text="Chưa có hóa đơn nào mới"
                android:textColor="@color/app_text_sub"
                android:textSize="14sp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvSetting"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="70dp"
        android:clipToPadding="false"
        android:visibility="gone"
        android:fillViewport="true"
        android:background="@color/app_bg">
        <include layout="@layout/layout_settings" />
    </androidx.core.widget.NestedScrollView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvInvoice"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="70dp"
        android:clipToPadding="false"
        android:visibility="gone"
        android:fillViewport="true"
        android:background="@color/app_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="Danh sách Hóa đơn"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_main"
                android:layout_marginBottom="16dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:clipToPadding="false"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvFilterDateAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tất cả"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_search_rounded"
                        android:backgroundTint="#195585"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:id="@+id/tvFilterDateThisMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này"
                        android:textColor="@color/app_text_main"
                        android:background="@drawable/bg_filter_chip"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp"/>
                    <TextView
                        android:id="@+id/tvFilterDateLastMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng trước"
                        android:textColor="@color/app_text_main"
                        android:background="@drawable/bg_filter_chip"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">
                
                <LinearLayout
                    android:id="@+id/btnCategorySelect"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_filter_chip"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/app_text_sub"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:id="@+id/tvCategorySelect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phân loại"
                        android:textColor="@color/app_text_main"
                        android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_filter_chip"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/app_text_sub"/>
                    <EditText
                        android:id="@+id/etSearchInvoicesTab"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Tìm hóa đơn, cửa hàng..."
                        android:textColorHint="@color/app_text_sub"
                        android:textColor="@color/app_text_main"
                        android:textSize="13sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInvoicesTab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvEmptyInvoiceTab"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="center"
                android:text="Không tìm thấy hóa đơn"
                android:textColor="@color/app_text_sub"
                android:textSize="14sp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- TAB THỐNG KÊ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsvReport"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="72dp"
        android:clipToPadding="false"
        android:visibility="gone"
        android:fillViewport="true"
        android:background="#F5F9FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                <ImageView
                    android:id="@+id/btnBackReport"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#444444"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Thống kê"
                    android:textColor="#222222"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bộ lọc thời gian"
                android:textColor="#222222"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Filter Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:id="@+id/tvReportDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hôm nay"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_search_rounded"
                    android:backgroundTint="#3D6EF5"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvReportWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tuần này"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_filter_chip"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvReportMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tháng này"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_filter_chip"
                    android:textColor="#444444"
                    android:textSize="14sp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvReportAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tất cả"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_filter_chip"
                    android:textColor="#444444"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Custom Range & Export Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/btnCustomRange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_filter_chip"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:id="@+id/tvCustomRangeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tuỳ chọn (Custom range)"
                        android:textColor="#444444"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="#3D6EF5"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnExportExcel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/bg_filter_chip"
                    android:backgroundTint="#E8F5E9"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xuất Excel"
                        android:textColor="#2E7D32"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_save"
                        app:tint="#2E7D32"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Pie Chart Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="220dp">
                        
                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/pieChart"
                            android:layout_width="220dp"
                            android:layout_height="match_parent"
                            android:layout_alignParentStart="true"/>

                        <LinearLayout
                            android:id="@+id/pieLegend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp">
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bar Chart Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@android:color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bar chart"
                        android:textColor="#222222"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Theo ngày / theo tháng"
                            android:textColor="#222222"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_centerVertical="true"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchChartMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>



        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/app_surface"
        app:elevation="24dp"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:itemIconTint="@drawable/bottom_nav_selector"
        app:itemTextColor="@drawable/bottom_nav_selector"
        app:itemRippleColor="@color/primary_blue" />

    <!-- Theme Transition Overlays -->
    <ImageView
        android:id="@+id/ivThemeTransitionOld"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:elevation="98dp"/>
    <ImageView
        android:id="@+id/ivThemeTransition"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:elevation="99dp"
        android:clickable="true"
        android:focusable="true"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fbAiAssistant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:fabSize="normal"
        android:src="@drawable/ic_ai_assistant"
        app:backgroundTint="@color/primary_blue"
        app:tint="#FFFFFF"
        app:elevation="8dp"
        app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior"
        android:contentDescription="AI Assistant" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>